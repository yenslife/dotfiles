# 目前會想要使用 ghostty 唯一的原因是，想要在 Neovim 中直接用 snack.nvim 看到圖片，但 Wezterm 看不到。
# 不過誰說我不能一次用兩個終端機呢？小孩才做選擇
# 設定好後可以用 Cmd + Shift + , 來 reload，調整透明度這種事情就很適合
# 下面是我參考 https://gist.github.com/dhh/a4b7de450276e336e3badec34fec0a75 的設定
# Tokyo Night 的風格

# Font configuration
font-size = 30
#font-family = JetBrains Mono
font-family = JetBrainsMono Nerd Font Mono Regular
font-family = Iansui-Regular

# # Window settings
window-padding-x = 20
window-padding-y = 20
# window-decoration = false
# background-opacity = 0.80

# Terminal settings
# 因為要 ssh 的機器幾乎都不支援 xterm-ghostty 所以這邊改成 xterm-256color，有點可惜
term = xterm-256color

# Mac Opt 設定，把左邊的 option key 設為 alt
macos-option-as-alt = left

# Keybindings
# keybind = f11=toggle_fullscreen

# Bright blue Tokyo Night style
background = 1a1b26
foreground = d5e7ff

# Cursor
cursor-color = 7dd3fc
cursor-text = 0b1026
cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor

# Normal colors
palette = 0=#1b2340
palette = 1=#ff7a93
palette = 2=#9ece6a
palette = 3=#e0af68
palette = 4=#38bdf8
palette = 5=#c084fc
palette = 6=#22d3ee
palette = 7=#c7d2fe

# Bright colors
palette = 8=#475569
palette = 9=#ff8fab
palette = 10=#b9f27c
palette = 11=#ffb86c
palette = 12=#60a5fa
palette = 13=#d8b4fe
palette = 14=#67e8f9
palette = 15=#eff6ff

# Selection color
selection-background = 2563eb
selection-foreground = eff6ff

